{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Debug",
      "type": "shell",
      "command": "make BUILD=Debug",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "Build Release",
      "type": "shell",
      "command": "make",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "Clean",
      "type": "shell",
      "command": "make clean",
      "group": {
        "kind": "build"
      }
    },
    {
      "label": "Rebuild CD",
      "type": "shell",
      // ..\\..\\mkpsxiso-2.20-win64\\mkpsxiso.exe make BUILD=Debug
      "command": "taskkill /IM pcsx-redux.main /F; make; ..\\..\\mkpsxiso-2.20-win64\\mkpsxiso.exe iso.xml -y; F:\\ps_emu\\ps1emut\\psx-redux\\pcsx-redux.exe"
    }
  ]
}